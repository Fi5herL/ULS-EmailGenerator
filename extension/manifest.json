{
  "manifest_version": 3,
  "name": "Flex Email Generator (Excel)",
  "short_name": "Flex Email Gen",
  "version": "1.0.0",
  "description": "Generate Flex Project emails on portal.ul.com from local .xlsx templates synced via OneDrive (no remote calls).",
  "author": "Fi5herL",
  "minimum_chrome_version": "100",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Flex Email Generator",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "popup/popup.html"
  },
  "permissions": [
    "storage",
    "clipboardWrite",
    "activeTab"
  ],
  "host_permissions": [
    "https://portal.ul.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://portal.ul.com/Project/Details/*"],
      "js": [
        "lib/js-yaml.min.js",
        "lib/xlsx.full.min.js",
        "content/gm-compat.js",
        "content/main.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
